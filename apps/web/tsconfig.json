{
  "extends": "@clira/config/tsconfig",
  "compilerOptions": {
    "lib": ["ES2022", "dom", "dom.iterable"],
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
