generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  output          = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// IDENTITY & SETTINGS
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id                                 String                     @id @default(uuid())
  email                              String                     @unique
  name                               String?
  createdAt                          DateTime                   @default(now())
  updatedAt                          DateTime                   @updatedAt
  masterPromptGenerated              Boolean                    @default(false)
  masterPromptQualityGenerated       Boolean                    @default(false)
  labelingOnboardingGenerated        Boolean                    @default(false)
  labelingOnboardingQualityGenerated Boolean                    @default(false)
  actionHistory                      ActionHistory[]
  batchSortJobs                      BatchSortJob[]
  emailCategorizationResult          EmailCategorizationResult?
  emailLearnings                     EmailLearning[]
  emailMappings                      EmailMapping[]
  emailSorts                         EmailSort[]
  feedbacks                          Feedback[]
  labels                             Label[]
  mailboxes                          Mailbox[]
  masterPrompts                      MasterPrompt[]
  replyInstructionDocs               ReplyInstructionDoc[]
  userSkills                         UserSkill[]
  accounts                           OAuthAccount[]
  inboxSearchDocuments               InboxSearchDocument[]
  inboxSearchCheckpoints             InboxSearchCheckpoint[]
  emailAlerts                        EmailAlert[]
  reminders                          Reminder[]
  pendingCalendarChanges             PendingCalendarChange[]
  pendingMcpActions                  PendingMcpAction[]
  mcpConnections                     McpConnection[]
  mcpExecutionAudits                 McpExecutionAudit[]
  threads                            Thread[]
  settings                           UserSettings?
  storedContentReferences            StoredContentReference[]
  tokenAccessAudits                  TokenAccessAudit[]
  telegramLink                       TelegramLink?
  telegramConversations              TelegramConversation[]
  telegramPairingApprovals           TelegramPairingRequest[]   @relation("TelegramPairingRequestApprovedByUser")
  aiTraceRuns                        AiTraceRun[]
}

model UserSettings {
  id                          String                      @id @default(cuid())
  userId                      String                      @unique
  autonomyLevel               Int                         @default(0)
  createdAt                   DateTime                    @default(now())
  updatedAt                   DateTime                    @updatedAt
  gmailHistoryId              String?
  allowedSenders              String[]                    @default([])
  blockedSenders              String[]                    @default([])
  enablePushNotifications     Boolean                     @default(true)
  replyScope                  ReplyScope                  @default(CONTACTS_ONLY)
  preferencesSaved            Boolean                     @default(false)
  calendarTimezone            String?
  calendarContextCalendarIds  String[]                    @default([])
  autoFileLowPriority         Int                         @default(50)
  autoSendConfidence          Int                         @default(95)
  newOnboardingCompleted      Boolean                     @default(false)
  autoSortingEnabled          Boolean                     @default(false)
  onboardingStep              String?
  persona                     OnboardingPersona?
  whatsappPhoneNumber         String?
  whatsappVerified            Boolean                     @default(false)
  twilioPhoneNumber           String?
  twilioVerified              Boolean                     @default(false)
  whatsappPromoSeen           Boolean                     @default(false)
  notificationDeliveryChannel NotificationDeliveryChannel @default(BOTH)
  user                        User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OAuthAccount {
  id                String   @id @default(cuid())
  userId            String
  mailboxId         String?  @unique
  provider          String
  providerAccountId String
  accessToken       String?
  refreshToken      String?
  scope             String?
  tokenType         String?
  expiresAt         Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mailbox           Mailbox? @relation(fields: [mailboxId], references: [id], onDelete: SetNull)

  @@unique([provider, providerAccountId])
}

model Mailbox {
  id                   String                  @id @default(cuid())
  userId               String
  provider             String
  providerAccountId    String
  emailAddress         String
  displayName          String?
  isPrimary            Boolean                 @default(false)
  status               String                  @default("CONNECTED")
  gmailHistoryId       String?
  gmailWatchExpiration DateTime?
  gmailWatchResourceId String?
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  user                 User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  oauthAccount         OAuthAccount?
  emails               Email[]
  threads              Thread[]
  labels               Label[]
  emailMappings        EmailMapping[]
  emailSorts           EmailSort[]
  inboxSearchDocuments   InboxSearchDocument[]
  inboxSearchCheckpoints InboxSearchCheckpoint[]

  @@unique([userId, provider, providerAccountId])
  @@index([userId])
  @@index([status])
  @@index([emailAddress])
}

// ─────────────────────────────────────────────────────────────────────────────
// EMAIL CORE
// ─────────────────────────────────────────────────────────────────────────────

model Thread {
  id            String   @id @default(uuid())
  userId        String
  mailboxId     String?
  subject       String
  snippet       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  gmailThreadId String?
  emails        Email[]
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mailbox       Mailbox? @relation(fields: [mailboxId], references: [id], onDelete: SetNull)

  @@unique([mailboxId, gmailThreadId])
  @@index([mailboxId])
}

model Email {
  id               String          @id @default(uuid())
  threadId         String
  mailboxId        String?
  messageId        String
  from             String
  to               String[]
  cc               String[]        @default([])
  subject          String
  body             String
  snippet          String?
  isSent           Boolean         @default(false)
  isDraft          Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  gmailThreadId    String?
  rfc2822MessageId String?
  inReplyTo        String?
  references       String?
  isProcessing     Boolean         @default(false)
  thread           Thread          @relation(fields: [threadId], references: [id], onDelete: Cascade)
  mailbox          Mailbox?        @relation(fields: [mailboxId], references: [id], onDelete: SetNull)
  feedback         Feedback?
  generatedDraft   GeneratedDraft?

  @@unique([mailboxId, messageId])
  @@index([mailboxId])
}

model Label {
  id                    String         @id @default(cuid())
  userId                String
  mailboxId             String?
  name                  String
  color                 String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  emailCount            Int            @default(0)
  exampleEmails         Json?
  gmailLabelId          String?
  isCustom              Boolean        @default(true)
  isSystemDefault       Boolean        @default(false)
  isSystemLabel         Boolean        @default(false)
  labelListVisibility   String?
  lastBatchSort         DateTime?
  messageListVisibility String?
  metaPrompt            String?
  systemLocked          Boolean        @default(false)
  emailMappings         EmailMapping[]
  emailSorts            EmailSort[]
  user                  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  mailbox               Mailbox?       @relation(fields: [mailboxId], references: [id], onDelete: SetNull)

  @@unique([mailboxId, gmailLabelId], name: "mailboxId_gmailLabelId")
  @@index([userId])
  @@index([mailboxId])
  @@index([userId, isCustom])
  @@index([userId, isSystemDefault])
}

model EmailMapping {
  id             String           @id @default(cuid())
  userId         String
  mailboxId      String?
  labelId        String
  emailAddress   String
  domain         String?
  subjectPattern String?
  isActive       Boolean          @default(true)
  mappingType    EmailMappingType @default(EMAIL)
  confidence     Float?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  label          Label            @relation(fields: [labelId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  mailbox        Mailbox?         @relation(fields: [mailboxId], references: [id], onDelete: SetNull)

  @@unique([mailboxId, emailAddress], name: "mailboxId_emailAddress")
  @@index([userId])
  @@index([mailboxId])
  @@index([userId, emailAddress])
  @@index([userId, domain])
  @@index([userId, subjectPattern])
  @@index([userId, isActive])
}

model EmailSort {
  id                    String        @id @default(cuid())
  userId                String
  mailboxId             String?
  batchSortJobId        String?
  source                String        @default("batch_sort")
  dedupeKey             String?       @unique
  labelId               String
  gmailMessageId        String
  gmailThreadId         String?
  confidence            Float?
  reasoning             String?
  wasManuallyOverridden Boolean       @default(false)
  sortedAt              DateTime      @default(now())
  batchSortJob          BatchSortJob? @relation(fields: [batchSortJobId], references: [id], onDelete: Cascade)
  label                 Label         @relation(fields: [labelId], references: [id], onDelete: Cascade)
  user                  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  mailbox               Mailbox?      @relation(fields: [mailboxId], references: [id], onDelete: SetNull)

  @@unique([mailboxId, gmailMessageId, batchSortJobId], name: "mailboxId_gmailMessageId_batchSortJobId")
  @@index([userId])
  @@index([mailboxId])
  @@index([batchSortJobId])
  @@index([labelId])
  @@index([gmailMessageId])
}

model BatchSortJob {
  id              String      @id @default(cuid())
  userId          String
  status          String
  emailsProcessed Int         @default(0)
  emailsSorted    Int         @default(0)
  emailsToReview  Int         @default(0)
  startedAt       DateTime    @default(now())
  completedAt     DateTime?
  errorMessage    String?
  llmTokensUsed   Int         @default(0)
  gmailHistoryId  String?
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailSorts      EmailSort[]

  @@index([startedAt])
  @@index([userId])
  @@index([userId, status])
}

model Feedback {
  id        String         @id @default(cuid())
  userId    String
  emailId   String         @unique
  action    FeedbackAction
  editDelta Json?
  createdAt DateTime       @default(now())
  email     Email          @relation(fields: [emailId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GeneratedDraft {
  id              String               @id @default(cuid())
  emailId         String               @unique
  gmailDraftId    String
  confidenceScore Float
  createdBy       GeneratedDraftSource @default(AI)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  email           Email                @relation(fields: [emailId], references: [id], onDelete: Cascade)
}

model EmailLearning {
  id              String   @id @default(cuid())
  userId          String
  emailFrom       String
  originalFolder  String
  correctedFolder String
  userReason      String?
  aiSummary       String
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([emailFrom])
  @@index([userId])
  @@index([userId, isActive])
}

model EmailCategorizationResult {
  id                   String   @id @default(cuid())
  userId               String   @unique
  categorizedEmails    Json
  folderSuggestions    Json
  totalEmailsAnalyzed  Int
  categorizationTimeMs Int
  llmTokensUsed        Int      @default(0)
  version              Int      @default(1)
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isActive])
}

model EmailAlert {
  id          String   @id @default(cuid())
  userId      String
  description String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isActive])
}

// ─────────────────────────────────────────────────────────────────────────────
// SEARCH / EMBEDDINGS (pgvector)
// ─────────────────────────────────────────────────────────────────────────────

model InboxSearchDocument {
  id            String             @id @default(cuid())
  userId        String
  mailboxId     String
  threadId      String
  messageId     String
  from          String
  to            String[]
  cc            String[]           @default([])
  subject       String
  snippet       String?
  bodyText      String
  sentAt        DateTime
  hasAttachment Boolean            @default(false)
  contentHash   String
  indexedAt     DateTime           @default(now())
  isDeleted     Boolean            @default(false)
  chunks        InboxSearchChunk[]
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  mailbox       Mailbox            @relation(fields: [mailboxId], references: [id], onDelete: Cascade)

  @@unique([mailboxId, messageId], name: "InboxSearchDocument_mailboxId_messageId_key")
  @@index([userId, sentAt(sort: Desc)], name: "InboxSearchDocument_userId_sentAt_idx")
  @@index([userId, mailboxId, sentAt(sort: Desc)], name: "InboxSearchDocument_userId_mailboxId_sentAt_idx")
  @@index([userId, from], name: "InboxSearchDocument_userId_from_idx")
}

model InboxSearchChunk {
  id             String                      @id @default(cuid())
  documentId     String
  chunkIndex     Int
  chunkText      String
  tokenCount     Int
  embedding      Unsupported("vector(768)")?
  embeddingModel String?
  embeddedAt     DateTime?
  document       InboxSearchDocument         @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, chunkIndex], name: "InboxSearchChunk_documentId_chunkIndex_key")
  @@index([documentId], name: "InboxSearchChunk_documentId_idx")
}

model InboxSearchCheckpoint {
  id                   String             @id @default(cuid())
  userId               String
  mailboxId            String
  lastHistoryIdIndexed String?
  backfillState        InboxBackfillState @default(PENDING)
  lastBackfillCursor   String?
  lastIndexedAt        DateTime?
  lagEstimate          Int?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  mailbox              Mailbox            @relation(fields: [mailboxId], references: [id], onDelete: Cascade)

  @@unique([userId, mailboxId], name: "InboxSearchCheckpoint_userId_mailboxId_key")
  @@index([backfillState, lastIndexedAt], name: "InboxSearchCheckpoint_backfillState_lastIndexedAt_idx")
}

// ─────────────────────────────────────────────────────────────────────────────
// AGENT OUTPUT & PROMPTS
// ─────────────────────────────────────────────────────────────────────────────

model MasterPrompt {
  id          String   @id @default(cuid())
  userId      String
  prompt      String
  version     Int      @default(1)
  isActive    Boolean  @default(true)
  isGenerated Boolean  @default(false)
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ReplyInstructionDoc {
  id        String   @id @default(cuid())
  userId    String
  target    String
  scope     String
  scopeKey  String?
  content   String
  version   Int      @default(1)
  isActive  Boolean  @default(true)
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, target, scope, scopeKey, isActive])
  @@index([userId, isActive])
}

model UserSkill {
  id             String    @id @default(cuid())
  userId         String
  slug           String
  name           String
  description    String
  body           String
  enabled        Boolean   @default(true)
  catalogSummary String
  archivedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, slug], name: "UserSkill_userId_slug_key")
  @@index([userId, archivedAt, enabled], name: "UserSkill_userId_archivedAt_enabled_idx")
  @@index([userId, updatedAt], name: "UserSkill_userId_updatedAt_idx")
}

model ActionHistory {
  id             String            @id @default(cuid())
  userId         String
  actionType     ActionHistoryType
  actionSummary  String
  actionDetails  Json?
  emailReference String?
  confidence     Float?
  undoable       Boolean           @default(false)
  promptState    String?
  metadata       Json?
  createdAt      DateTime          @default(now())
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model StoredContentReference {
  id               String   @id @default(cuid())
  contentRefId     String   @unique
  ownerUserId      String
  sourceKind       String
  locator          String
  displayName      String?
  mimeHint         String?
  trustClass       String
  requiresApproval Boolean  @default(false)
  capability       String
  provenance       Json
  data             Bytes
  sizeBytes        Int
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@index([ownerUserId, createdAt(sort: Desc)])
}

// ─────────────────────────────────────────────────────────────────────────────
// APPROVAL-GATED ACTIONS
// ─────────────────────────────────────────────────────────────────────────────

model PendingCalendarChange {
  id             String                      @id @default(cuid())
  userId         String
  conversationId String
  plan           Json
  resolvedTarget Json?
  userTimezone   String
  userRequest    String
  status         PendingCalendarChangeStatus @default(PENDING)
  expiresAt      DateTime
  consumedAt     DateTime?
  cancelledAt    DateTime?
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt
  user           User                        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, conversationId, status])
  @@index([userId, conversationId, createdAt])
  @@index([expiresAt, status])
}

model PendingMcpAction {
  id             String                 @id @default(cuid())
  userId         String
  conversationId String
  connectionId   String
  toolName       String
  modelToolName  String
  displayTitle   String
  actionClass    McpActionClass
  trustClass     McpTrustClass
  userRequest    String
  args           Json
  previewText    String
  previewSummary Json?
  status         PendingMcpActionStatus @default(PENDING)
  idempotencyKey String
  expiresAt      DateTime
  consumedAt     DateTime?
  cancelledAt    DateTime?
  resultSummary  Json?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  user           User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  connection     McpConnection          @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([userId, conversationId, status])
  @@index([userId, conversationId, createdAt])
  @@index([connectionId, status, createdAt])
  @@index([expiresAt, status])
  @@index([idempotencyKey])
}

// ─────────────────────────────────────────────────────────────────────────────
// MCP SUBSYSTEM
// ─────────────────────────────────────────────────────────────────────────────

model McpConnection {
  id                  String              @id @default(cuid())
  userId              String
  serverKey           String
  displayName         String
  packDescription     String?
  disabledToolNames   Json                @default("[]")
  transportType       McpTransportType
  transportConfig     Json
  authMode            McpAuthMode         @default(NONE)
  encryptedSecrets    String?
  status              McpConnectionStatus @default(PENDING)
  trustClass          McpTrustClass       @default(USER_CONFIGURED)
  degradedReason      String?
  syncDiagnostics     Json?
  healthDiagnostics   Json?
  lastSyncedAt        DateTime?
  lastHealthCheckedAt DateTime?
  consecutiveFailures Int                 @default(0)
  circuitOpenedAt     DateTime?
  circuitOpenUntil    DateTime?
  disabledAt          DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  user                User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  toolManifests       McpToolManifest[]
  executionAudits     McpExecutionAudit[]
  pendingActions      PendingMcpAction[]

  @@unique([userId, serverKey], name: "McpConnection_userId_serverKey_key")
  @@index([userId, status], name: "McpConnection_userId_status_idx")
  @@index([userId, updatedAt], name: "McpConnection_userId_updatedAt_idx")
}

model McpToolManifest {
  id              String          @id @default(cuid())
  connectionId    String
  toolName        String
  toolSlug        String
  modelToolName   String
  displayTitle    String
  description     String?
  inputSchema     Json
  outputSchema    Json?
  annotations     Json?
  actionClass     McpActionClass
  latencyClass    McpLatencyClass @default(STANDARD)
  safeForAutoUse  Boolean         @default(false)
  syncDiagnostics Json?
  lastSyncedAt    DateTime
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  connection      McpConnection   @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([connectionId, toolName], name: "McpToolManifest_connectionId_toolName_key")
  @@unique([connectionId, modelToolName], name: "McpToolManifest_connectionId_modelToolName_key")
  @@index([connectionId, actionClass], name: "McpToolManifest_connectionId_actionClass_idx")
}

model McpExecutionAudit {
  id             String         @id @default(cuid())
  userId         String
  connectionId   String
  toolName       String
  modelToolName  String
  actionClass    McpActionClass
  args           Json?
  resultSummary  Json?
  latencyMs      Int?
  cacheHit       Boolean        @default(false)
  freshness      Json?
  degraded       Boolean        @default(false)
  errorClass     String?
  idempotencyKey String?
  createdAt      DateTime       @default(now())
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  connection     McpConnection  @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt], name: "McpExecutionAudit_userId_createdAt_idx")
  @@index([connectionId, createdAt], name: "McpExecutionAudit_connectionId_createdAt_idx")
  @@index([connectionId, toolName, createdAt], name: "McpExecutionAudit_connectionId_toolName_createdAt_idx")
}

// ─────────────────────────────────────────────────────────────────────────────
// REMINDERS & AUDIT
// ─────────────────────────────────────────────────────────────────────────────

model Reminder {
  id              String         @id @default(cuid())
  userId          String
  title           String
  description     String?
  context         String?
  scheduledAt     DateTime
  status          ReminderStatus @default(PENDING)
  recurrence      Json?
  deliveredAt     DateTime?
  deliveryClaimId String?
  dismissedAt     DateTime?
  snoozedUntil    DateTime?
  snoozeCount     Int            @default(0)
  linkedEmailId   String?
  linkedEventId   String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, status])
  @@index([deliveryClaimId])
  @@index([scheduledAt, status])
}

model TokenAccessAudit {
  id        String         @id @default(cuid())
  userId    String
  tokenType CredentialKind @default(BOTH)
  purpose   String
  requester String
  metadata  Json?
  createdAt DateTime       @default(now())
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// AI TRACING (added for observability — not in original, added for Phase 2 prep)
// ─────────────────────────────────────────────────────────────────────────────

model AiTraceRun {
  id        String        @id @default(cuid())
  userId    String?
  runType   String
  status    String        @default("running")
  metadata  Json?
  startedAt DateTime      @default(now())
  endedAt   DateTime?
  spans     AiTraceSpan[]
  user      User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, startedAt(sort: Desc)])
  @@index([runType, startedAt(sort: Desc)])
}

model AiTraceSpan {
  id        String     @id @default(cuid())
  runId     String
  parentId  String?
  spanType  String
  name      String
  input     Json?
  output    Json?
  error     String?
  startedAt DateTime   @default(now())
  endedAt   DateTime?
  latencyMs Int?
  metadata  Json?
  run       AiTraceRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([runId, startedAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// MESSAGING CHANNELS
// ─────────────────────────────────────────────────────────────────────────────

model WhatsAppConversation {
  id        String                     @id @default(cuid())
  userId    String
  waId      String
  status    WhatsAppConversationStatus @default(ACTIVE)
  createdAt DateTime                   @default(now())
  updatedAt DateTime                   @updatedAt
  messages  WhatsAppMessage[]

  @@unique([userId, waId])
  @@index([userId])
  @@index([userId, status])
}

model WhatsAppMessage {
  id             String                   @id @default(cuid())
  conversationId String
  waMessageId    String?
  direction      WhatsAppMessageDirection
  content        String
  role           WhatsAppMessageRole
  metadata       Json?
  createdAt      DateTime                 @default(now())
  conversation   WhatsAppConversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([conversationId, createdAt])
  @@index([waMessageId])
}

model TelegramConversation {
  id             String                     @id @default(cuid())
  userId         String
  chatId         String
  telegramUserId String
  status         TelegramConversationStatus @default(ACTIVE)
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt
  user           User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages       TelegramMessage[]

  @@unique([userId, chatId])
  @@index([userId])
  @@index([userId, status])
  @@index([userId, updatedAt])
}

model TelegramMessage {
  id                String                   @id @default(cuid())
  conversationId    String
  telegramUpdateId  BigInt?                  @unique
  telegramMessageId String?
  direction         TelegramMessageDirection
  content           String
  role              TelegramMessageRole
  metadata          Json?
  createdAt         DateTime                 @default(now())
  conversation      TelegramConversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([conversationId, createdAt])
  @@index([telegramMessageId])
}

model TelegramLink {
  id                String    @id @default(cuid())
  userId            String    @unique
  telegramUserId    String    @unique
  chatId            String
  telegramUsername  String?
  telegramFirstName String?
  isActive          Boolean   @default(true)
  linkedAt          DateTime  @default(now())
  lastSeenAt        DateTime?
  deactivatedAt     DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isActive])
  @@index([userId, updatedAt])
}

model TelegramPairingRequest {
  id                String                @id @default(cuid())
  telegramUserId    String
  chatId            String
  telegramUsername  String?
  telegramFirstName String?
  pairingCode       String                @unique
  status            TelegramPairingStatus @default(PENDING)
  expiresAt         DateTime
  approvedAt        DateTime?
  rejectedAt        DateTime?
  approvedByUserId  String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  approvedByUser    User?                 @relation("TelegramPairingRequestApprovedByUser", fields: [approvedByUserId], references: [id], onDelete: SetNull)

  @@index([telegramUserId, chatId])
  @@index([status, expiresAt])
  @@index([approvedByUserId, status])
}

model TelegramPollerState {
  id           String   @id @default(cuid())
  workerKey    String   @unique
  lastUpdateId Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model TwilioConversation {
  id          String                   @id @default(cuid())
  userId      String
  phoneNumber String
  status      TwilioConversationStatus @default(ACTIVE)
  messageType TwilioMessageType        @default(SMS)
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  messages    TwilioMessage[]

  @@unique([userId, phoneNumber])
  @@index([userId])
  @@index([userId, status])
}

model TwilioMessage {
  id             String                 @id @default(cuid())
  conversationId String
  twilioSid      String?
  direction      TwilioMessageDirection
  content        String
  role           TwilioMessageRole
  metadata       Json?
  createdAt      DateTime               @default(now())
  conversation   TwilioConversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([twilioSid, direction])
  @@index([conversationId])
  @@index([conversationId, createdAt])
}

